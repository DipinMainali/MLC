// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USERS (Unified - admins, editors, viewers, contributors)
// ============================================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  
  // Everything about user roles & permissions
  data         Json     @default("{}")
  
  lastLoginAt  DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([data])  // Can index specific JSON paths in PostgreSQL
}

// ============================================
// 2. ROLES (Define once, reuse)
// ============================================
model Role {
  id          String   @id @default(cuid())
  name        String   @unique  // "super_admin", "project_manager", "support"
  description String?
  data        Json     @default("{}")  // ⭐ Permissions stored here
  createdAt   DateTime @default(now())

  @@index([name])
}

// ============================================
// 3. USER ROLES (Many-to-Many)
// ============================================
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  data      Json     @default("{}")  // ⭐ Role-specific config (e.g., assigned projects)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================
// 4. PROJECTS 
// ============================================
model Project {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  data       Json     @default("{}")
  isPublished Boolean @default(false)
  publishedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
}

// ============================================
// 5. INQUIRIES 
// ============================================
model Inquiry {
  id         String   @id @default(cuid())
  data       Json     @default("{}")
  status     String   @default("new")
  assignedTo String?  // Support person handling this inquiry
  adminNotes String?
  createdAt  DateTime @default(now())

  @@index([status])
  @@index([assignedTo])
}

// ============================================
// 6. SERVICES 
// ============================================
model Service {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  icon             String?
  shortDescription String?
  fullDescription  String?
  sortOrder        Int             @default(0)
  isPublished      Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  features         ServiceFeature[]

  @@index([slug])
  @@index([isPublished])
  @@index([sortOrder])
}

model ServiceFeature {
  id        String   @id @default(cuid())
  serviceId String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([sortOrder])
  @@unique([serviceId, sortOrder])
}

// ============================================
// 7. SITE SETTINGS 
// ============================================
model SiteSetting {
  id        String   @id @default("singleton")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// ============================================
// 8. ACTIVITY LOGS (Enhanced with role info)
// ============================================
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  data      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}



